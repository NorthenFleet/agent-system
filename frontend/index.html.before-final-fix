          if (osLower.includes('mac')) return 'mac';
          if (osLower.includes('ubuntu') || osLower.includes('linux')) return 'linux';
          if (osLower.includes('synology')) return 'nas';
          if (osLower.includes('openwrt') || osLower.includes('router')) return 'router';
          return 'linux';
