    // ============================================
    // 移动端手势支持
    // ============================================
    let touchStartX = 0;
    let touchStartY = 0;
    let touchEndX = 0;
    let touchEndY = 0;
    const swipeThreshold = 50; // 最小滑动距离
    const swipeAngleThreshold = 45; // 角度阈值 (度)

    document.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      touchEndY = e.changedTouches[0].screenY;
      handleGesture();
    }, { passive: true });

    function handleGesture() {
      const deltaX = touchEndX - touchStartX;
      const deltaY = touchEndY - touchStartY;
      const absDeltaX = Math.abs(deltaX);
      const absDeltaY = Math.abs(deltaY);

      // 判断是水平滑动还是垂直滑动
      if (absDeltaX > absDeltaY) {
        // 水平滑动
        if (absDeltaX > swipeThreshold) {
          const angle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);
          
          // 确保角度在水平方向
          if (Math.abs(angle) < swipeAngleThreshold || Math.abs(angle) > 180 - swipeAngleThreshold) {
            if (deltaX > 0) {
              onSwipeRight();
            } else {
              onSwipeLeft();
            }
          }
        }
      } else {
        // 垂直滑动
        if (absDeltaY > swipeThreshold) {
          const angle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);
          
          // 确保角度在垂直方向
          if (Math.abs(angle - 90) < swipeAngleThreshold || Math.abs(angle + 90) < swipeAngleThreshold) {
            if (deltaY > 0) {
              onSwipeDown();
            } else {
              onSwipeUp();
            }
          }
        }
      }
    }

    // 手势处理函数
    function onSwipeLeft() {
      console.log('[Gesture] Swipe Left');
      // 左滑：关闭侧边栏
      const app = document.querySelector('#app').__vue_app__;
      if (app?._instance?.proxy) {
        app._instance.proxy.sidebarOpen = false;
      }
    }

    function onSwipeRight() {
      console.log('[Gesture] Swipe Right');
      // 右滑：打开侧边栏 (在移动端)
      if (window.innerWidth <= 768) {
        const app = document.querySelector('#app').__vue_app__;
        if (app?._instance?.proxy) {
          app._instance.proxy.sidebarOpen = true;
        }
      }
    }

    function onSwipeUp() {
      console.log('[Gesture] Swipe Up');
      // 上滑：可以添加刷新功能
