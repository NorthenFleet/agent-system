        getDeviceIcon(os) {
          if (!os) return 'fab fa-linux';
          const osLower = os.toLowerCase();
          if (osLower.includes('mac')) return 'fab fa-apple';
          if (osLower.includes('ubuntu') || osLower.includes('linux')) return 'fab fa-linux';
          if (osLower.includes('synology')) return 'fas fa-hdd';
          if (osLower.includes('openwrt') || osLower.includes('router')) return 'fas fa-wifi';
          return 'fab fa-linux';
