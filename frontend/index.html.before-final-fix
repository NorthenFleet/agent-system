        getDevicesByType(type) {
          if (type === 'router') {
            return this.devices.filter(d => d.role && d.role.includes('路由'));
          }
          return this.devices;
        },
        async refreshData() {
          this.loading = true;
          await this.load();
        this.$nextTick(() => {
          this.initCharts();
        });
          this.loading = false;
        },
        async load() {
          try {
            const [agentsRes, statusRes, devicesRes, tasksRes] = await Promise.all([
              fetch(API_BASE + '/api/agents'),
              fetch(API_BASE + '/api/team/status'),
              fetch(API_BASE + '/api/devices'),
              fetch(API_BASE + '/api/tasks'),
            ]);
            const agentsData = await agentsRes.json();
            const statusData = await statusRes.json();
            const devicesData = await devicesRes.json();
            const tasksData = await tasksRes.json();
            this.agents = agentsData.agents || [];
            this.stats = statusData;
            this.devices = devicesData.devices || [];
            this.tasks = tasksData.tasks || [];
            this.isConnected = true;
            this.lastUpdate = new Date().toLocaleString('zh-CN');
            this.$nextTick(() => {
              this.initCharts();
            });
          } catch (e) {
            console.error('API 请求失败', e);
            this.isConnected = false;
