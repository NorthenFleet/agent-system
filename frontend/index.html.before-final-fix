  <script>
    const API_BASE = (function() {
      const u = window.location;
      const host = u.hostname || 'localhost';
      const port = '3020';
      return u.protocol + '//' + host + ':' + port;
    })();

    const { createApp } = Vue;
    createApp({
      data() {
        return {
          currentView: 'dashboard',
          sidebarOpen: false,
          selectedAgent: null,
          agentDetails: null,
          loading: false,
          isConnected: false,
          lastUpdate: '-',
          agents: [],
          devices: [],
          tasks: [],
          stats: {
            total_agents: 0,
            online: 0,
            busy: 0,
            idle: 0,
            pending: 0,
            autobots_count: 0,
            ninja_turtles_count: 0,
            task_stats: {}
          },
          emailStats: {
            last_check: null,
            total_unread: 0,
            today_checked: 0,
            today_invoices: 0,
            today_papers: 0,
            ignored: 0
          },
          codexTasks: [],
          heartbeat: {
            last_heartbeat: null,
            next_report: null,
            tasks_completed_today: 0
          },
          stats: {
            total_agents: 0,
            online: 0,
            busy: 0,
            idle: 0,
            pending: 0,
            autobots_count: 0,
            ninja_turtles_count: 0,
          },
          recentActivities: [
            { type: 'success', icon: 'fas fa-check', text: '拉斐尔完成了任务 "团队看板后端 API"', time: '10 分钟前' },
            { type: 'info', icon: 'fas fa-info', text: '大黄蜂开始了新任务 "Unity 兵棋开发"', time: '30 分钟前' },
            { type: 'warning', icon: 'fas fa-exclamation', text: '系统检测到铁皮设备离线', time: '1 小时前' },
            { type: 'success', icon: 'fas fa-user-plus', text: '新智能体 "米开朗基罗" 加入团队', time: '2 小时前' },
          ],
          statusChart: null,
          taskChart: null,
          deviceChart: null,
          earthChart: null,
          rotateEarth: true,
        };
      },
      computed: {
        pageTitle() {
          const titles = {
            dashboard: '仪表盘',
            agents: '智能体团队',
            devices: '设备清单',
            tasks: '任务看板',
            architecture: '集群架构',
            earth: '开源地球',
          };
          return titles[this.currentView] || '仪表盘';
        },
        autobots() {
          return this.agents.filter(a => a.team === 'autobots');
        },
        ninjaTurtles() {
          return this.agents.filter(a => a.team === 'ninja_turtles');
        },
        onlineAgents() {
          return this.agents.filter(a => a.status === 'online' || a.status === 'busy');
        },
        completedTasks() {
          return this.tasks.filter(t => t.status === 'done').length;
        },
        inProgressTasks() {
          return this.tasks.filter(t => t.status === 'in_progress').length;
        },
        pendingTasks() {
          return this.tasks.filter(t => t.status === 'pending').length;
        },
        agentTasks() {
          return this.codexTasks.filter(t => t.mode === 'agent').length;
        },
        planTasks() {
          return this.codexTasks.filter(t => t.mode === 'plan').length;
        },
        agentTasks() {
          return this.codexTasks.filter(t => t.mode === 'agent').length;
        },
        planTasks() {
          return this.codexTasks.filter(t => t.mode === 'plan').length;
        },
        devicesByLocation() {
          const groups = {};
          this.devices.forEach(device => {
            const loc = device.location || '未分类';
            if (!groups[loc]) groups[loc] = [];
            groups[loc].push(device);
          });
          return groups;
        },
        totalCpuCores() {
          return this.devices.reduce((sum, d) => {
            if (d.specs && d.specs.cpu) {
              const match = d.specs.cpu.match(/(\d+)/);
              return sum + (match ? parseInt(match[1]) : 0);
            }
            return sum;
          }, 0);
        },
        totalRam() {
          return this.devices.reduce((sum, d) => {
            if (d.specs && d.specs.ram) {
              const match = d.specs.ram.match(/(\d+)/);
              return sum + (match ? parseInt(match[1]) : 0);
            }
            return sum;
          }, 0);
        },
      },
      methods: {
        async fetchAgentDetails(agentId) {
          try {
            const res = await fetch(`/api/agents/${agentId}/details`);
            const data = await res.json();
            this.agentDetails = data;
            this.selectedAgent = agentId;
          } catch (error) {
            console.error('获取智能体详情失败:', error);
          }
        },
        closeAgentDetails() {
          this.selectedAgent = null;
          this.agentDetails = null;
        },
        getFileIcon(type) {
          const icons = {'memory': 'fas fa-brain', 'task': 'fas fa-tasks', 'skill': 'fas fa-magic', 'doc': 'fas fa-file-alt', 'architecture': 'fas fa-sitemap', 'code': 'fas fa-code', 'script': 'fas fa-file-code', 'remote': 'fas fa-server'};
          return icons[type] || 'fas fa-file';
        },
        getTypeLabel(type) {
          const labels = {'memory': '记忆', 'task': '任务', 'skill': '技能', 'doc': '文档', 'architecture': '架构', 'code': '代码', 'script': '脚本', 'remote': '远程'};
          return labels[type] || type;
        },
        async previewDocument(filepath) {
          try {
            const res = await fetch(`/api/documents/preview?filepath=${encodeURIComponent(filepath)}`);
            const data = await res.json();
            this.$alert(data.content, filepath, {confirmButtonText: '关闭', width: '800px'});
          } catch (error) {
            this.$message.error('预览失败：' + error);
          }
        },
        async fetchOpenClawData() {
          try {
            const emailRes = await fetch('/api/email/stats');
            const emailData = await emailRes.json();
            this.emailStats = emailData;
            
            // 获取 Codex 任务
            const codexRes = await fetch('/api/codex/tasks');
            const codexData = await codexRes.json();
            this.codexTasks = codexData.tasks || [];
            
            // 获取心跳状态
            const heartbeatRes = await fetch('/api/heartbeat/state');
            const heartbeatData = await heartbeatRes.json();
            this.heartbeat = heartbeatData;
            
            this.lastUpdate = new Date().toLocaleTimeString('zh-CN');
          } catch (error) {
            console.error('获取 OpenClaw 数据失败:', error);
          }
        },
        toggleSidebar() {
          this.sidebarOpen = !this.sidebarOpen;
        },
        closeSidebar() {
          this.sidebarOpen = false;
        },

        statusText(s) {
          const map = { online: '在线', busy: '忙碌', idle: '空闲', pending: '待机' };
          return map[s] || s;
