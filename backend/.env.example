# ============================================
# API 安全配置示例文件
# 复制为 .env 并修改配置
# ============================================

# 速率限制配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100

# API Key 认证配置
# 生产环境请使用强随机密钥
API_KEYS=dashboard-key-001,dashboard-key-002,admin-key-master
AUTH_REQUIRED=false

# 请求日志配置
LOG_FILE_PATH=request_logs.jsonl
LOG_MAX_MEMORY=1000
LOG_INCLUDE_BODY=false

# 异常检测配置
ALERT_FAILED_AUTH=5
ALERT_TIME_WINDOW=300
ALERT_REQUEST_RATE=200

# 告警通知配置
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENTS=admin@example.com
ALERT_WEBHOOK_URL=

# Redis 配置（可选，用于生产环境）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
