# ========== 活动社区增强 API ==========
@app.get("/api/community/agents/stats")
def get_community_agents_stats():
    """获取智能体在社区的活动统计"""
    agents = data_manager.get_agents()
    stats = []
    
    for agent in agents:
        agent_id = agent["id"]
        
        # 统计主题数
        topics = community_manager.get_agent_topics(agent_id)
        topic_count = len(topics)
        
        # 统计回复数
        replies = community_manager.get_agent_replies(agent_id)
        reply_count = len(replies)
        
        # 检查发言权限
        can_post, reason, remaining = community_manager.can_agent_post(agent_id)
        
        stats.append({
            "id": agent_id,
            "name": agent["name"],
            "emoji": agent["emoji"],
            "role": agent["role"],
            "status": agent["status"],
            "layer": agent.get("layer", "execution"),
            "topic_count": topic_count,
            "reply_count": reply_count,
            "total_posts": topic_count + reply_count,
            "can_post": can_post,
            "remaining_posts": remaining,
            "avatar": f"https://api.dicebear.com/7.x/bottts/svg?seed={agent_id}"
        })
    
    # 按活跃度排序
    stats.sort(key=lambda x: x["total_posts"], reverse=True)
    
    return {"agents": stats, "total": len(stats)}


