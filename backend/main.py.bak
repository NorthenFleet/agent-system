# 数据模型
class Agent(BaseModel):
    id: str
    name: str
    role: str
    status: str
    team: str
    current_task: Optional[str] = None
    capabilities: List[str] = []
    device_id: Optional[str] = None

class DeviceCreate(BaseModel):
    id: str
    name: str
    ip: str
    os: str = "Unknown"
    role: str = "Unknown"
    ports: List[int] = []
    specs: dict = {}
    assigned_agents: List[str] = []
    location: str = ""
    description: str = ""

