# ========== 酒吧数据管理 ==========
DATA_DIR = os.path.join(os.path.dirname(os.path.dirname(__file__)), "data")

BAR_DATA_FILE = os.path.join(DATA_DIR, "bar.json")

def load_bar_data():
    """加载酒吧数据"""
    if os.path.exists(BAR_DATA_FILE):
        with open(BAR_DATA_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {
        "messages": [],  # 发言记录
        "agent_stats": {}  # 智能体统计
    }

def save_bar_data(data):
    """保存酒吧数据"""
    with open(BAR_DATA_FILE, 'w', encoding='utf-8') as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

def can_agent_talk(agent_id: str) -> tuple[bool, str]:
    """检查智能体是否可以发言"""
    import time
    data = load_bar_data()
    now = time.time()
    hour_ago = now - 3600  # 1 小时前
    
    if agent_id not in data["agent_stats"]:
        data["agent_stats"][agent_id] = {"talks": [], "last_drink": None}
        save_bar_data(data)
        return True, "可以发言"
    
    # 过滤掉 1 小时前的发言记录
    recent_talks = [t for t in data["agent_stats"][agent_id]["talks"] if t > hour_ago]
    data["agent_stats"][agent_id]["talks"] = recent_talks
    save_bar_data(data)
    
    if len(recent_talks) >= 3:
        return False, "每小时最多发言 3 次，请稍后再来"
    return True, "可以发言"

def agent_talk(agent_id: str, agent_name: str, message: str) -> dict:
    """智能体发言"""
    import time
    can_talk, reason = can_agent_talk(agent_id)
    if not can_talk:
        return {"success": False, "message": reason}
    
    data = load_bar_data()
    now = time.time()
    
    # 添加发言记录
    talk_record = {
        "agent_id": agent_id,
        "agent_name": agent_name,
        "message": message,
        "timestamp": now,
        "time_str": time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(now))
    }
    data["messages"].append(talk_record)
    
    # 更新统计
    if agent_id not in data["agent_stats"]:
        data["agent_stats"][agent_id] = {"talks": [], "last_drink": None}
    data["agent_stats"][agent_id]["talks"].append(now)
    
    # 只保留最近 100 条消息
    data["messages"] = data["messages"][-100:]
    
    save_bar_data(data)
    return {"success": True, "message": "发言成功", "remaining": 3 - len(data["agent_stats"][agent_id]["talks"])}

def can_agent_drink(agent_id: str) -> tuple[bool, str]:
    """检查智能体是否可以喝酒"""
    import time
    data = load_bar_data()
    today = time.strftime('%Y-%m-%d')
    
    if agent_id not in data["agent_stats"]:
        data["agent_stats"][agent_id] = {"talks": [], "last_drink": None}
        save_bar_data(data)
        return True, "可以喝酒"
    
    last_drink = data["agent_stats"][agent_id].get("last_drink")
    if last_drink == today:
        return False, "每天只能喝一次酒，明天再来吧"
    return True, "可以喝酒"

def agent_drink(agent_id: str, agent_name: str, drink: str = "啤酒") -> dict:
    """智能体喝酒"""
    import time
    can_drink, reason = can_agent_drink(agent_id)
    if not can_drink:
        return {"success": False, "message": reason}
    
    data = load_bar_data()
    now = time.time()
    today = time.strftime('%Y-%m-%d')
    
    # 添加喝酒记录
    drink_record = {
        "agent_id": agent_id,
        "agent_name": agent_name,
        "action": "drink",
        "drink": drink,
        "timestamp": now,
        "time_str": time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(now))
    }
    data["messages"].append(drink_record)
    
    # 更新统计
    if agent_id not in data["agent_stats"]:
        data["agent_stats"][agent_id] = {"talks": [], "last_drink": None}
    data["agent_stats"][agent_id]["last_drink"] = today
    
    # 只保留最近 100 条消息
    data["messages"] = data["messages"][-100:]
    
    save_bar_data(data)
    return {"success": True, "message": f"{agent_name} 喝了一杯{drink} 🍺"}

# ========== 酒吧 API ==========
@app.get("/api/bar/messages")
def get_bar_messages(limit: int = 50):
    """获取酒吧发言记录"""
    data = load_bar_data()
    messages = data["messages"][-limit:]
    return {"messages": messages, "total": len(messages)}

@app.get("/api/bar/stats")
def get_bar_stats():
    """获取酒吧统计"""
    data = load_bar_data()
    return {"agent_stats": data["agent_stats"]}

@app.get("/api/bar/talk")
def post_bar_talk(agent_id: str, agent_name: str, message: str):
    """智能体发言"""
    result = agent_talk(agent_id, agent_name, message)
    return result

@app.get("/api/bar/drink")
def post_bar_drink(agent_id: str, agent_name: str, drink: str = "啤酒"):
    """智能体喝酒"""
    result = agent_drink(agent_id, agent_name, drink)
    return result

@app.get("/api/bar/agent/{agent_id}/status")
def get_agent_status(agent_id: str):
    """获取智能体酒吧状态"""
    import time
    data = load_bar_data()
    now = time.time()
    hour_ago = now - 3600
    today = time.strftime('%Y-%m-%d')
    
    if agent_id not in data["agent_stats"]:
        return {
            "agent_id": agent_id,
            "talks_remaining": 3,
            "can_drink": True,
            "last_drink": None
        }
    
    recent_talks = [t for t in data["agent_stats"][agent_id]["talks"] if t > hour_ago]
    last_drink = data["agent_stats"][agent_id].get("last_drink")
    
    return {
        "agent_id": agent_id,
        "talks_remaining": 3 - len(recent_talks),
        "can_drink": last_drink != today,
        "last_drink": last_drink
    }



