        self.agents = self._load_agents()
    
    def _load_agents(self) -> List[dict]:
        """加载智能体数据"""
        if os.path.exists(self.agents_file):
            with open(self.agents_file, 'r', encoding='utf-8') as f:
                return json.load(f)
        return self._init_default_agents()
    
